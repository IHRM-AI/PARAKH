# Self-hosted GenAI services. Copy to .env and fill in.
# GPU instances are started only at run/demo time; leave blank to disable the GenAI layer.

# API hardening (all optional; defaults keep the live demo working).
# Comma-separated CORS allowlist. Unset falls back to localhost dev origins plus
# the live ALB origin. Set to lock the API to specific origins.
CORS_ORIGINS=
# Optional API key. Unset means no auth (demo default). When set, callers must
# send a matching x-api-key header.
API_KEY=

# Gemma-4 served via vLLM (OpenAI-compatible chat completions endpoint)
VLLM_URL=
VLLM_MODEL_NAME=gemma-4-31b-it

# OCR microservice (multi-language and handwritten document extraction)
OCR_SERVICE_URL=

# Self-hosted Firecrawl (news / adverse-media acquisition)
FIRECRAWL_BASE_URL=
